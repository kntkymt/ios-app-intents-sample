+def _generate_dependency_metadata_bundles(
+        *,
+        actions,
+        deps,
+        label,
+        platform_prerequisites,
+        root_module_names,
+        target_triples,
+        json_tool):
+    """Generates a Metadata.appintents bundle for each transitive App Intents dependency module.
+
+    Mirroring the behavior of xcodebuild, each metadata bundle for a statically linked dependency
+    module is generated with the metadata bundles of its own transitive dependencies passed via
+    `--static-metadata-file-list`, so App Intents type references across modules can be resolved.
+
+    Args:
+        actions: The actions provider from ctx.actions.
+        deps: List of dependencies implementing the AppIntents protocol for a single split.
+        label: Label of the target being built.
+        platform_prerequisites: Struct containing information on the platform being targeted.
+        root_module_names: List of module names handled by the root metadata bundle, which must be
+            excluded from dependency metadata bundle generation.
+        target_triples: List of Apple target triples from `CcToolchainInfo` providers.
+        json_tool: A `files_to_run` wrapping Python's `json.tool` module.
+    Returns:
+        List of Files referencing the Metadata.appintents bundles of all transitive dependency
+        modules, ordered so that dependencies appear before their dependents.
+    """
+    dependency_metadata = depset(
+        order = "postorder",
+        transitive = [
+            dep[AppIntentsInfo].transitive_dependency_metadata
+            for dep in deps
+        ],
+    ).to_list()
+
+    # Iterating in postorder guarantees that the metadata bundles for the dependencies of a given
+    # module have already been generated when that module's own bundle is generated.
+    metadata_bundles_by_module_name = {}
+    for metadata in dependency_metadata:
+        if metadata.module_name in root_module_names:
+            continue
+        if metadata.module_name in metadata_bundles_by_module_name:
+            continue
+        metadata_bundles_by_module_name[metadata.module_name] = (
+            generate_app_intents_metadata_bundle(
+                actions = actions,
+                apple_fragment = platform_prerequisites.apple_fragment,
+                constvalues_files = list(metadata.swiftconstvalues_files),
+                dependency_metadata_bundles = [
+                    metadata_bundles_by_module_name[module_name]
+                    for module_name in metadata.dependency_module_names
+                    if module_name in metadata_bundles_by_module_name
+                ],
+                intents_module_names = [metadata.module_name],
+                is_dependency_module = True,
+                label = label.relative("{}_{}".format(label.name, metadata.module_name)),
+                platform_prerequisites = platform_prerequisites,
+                source_files = list(metadata.swift_source_files),
+                target_triples = target_triples,
+                xcode_version_config = platform_prerequisites.xcode_version_config,
+                json_tool = json_tool,
+            )
+        )
+
+    return metadata_bundles_by_module_name.values()
+
