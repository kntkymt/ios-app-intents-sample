diff --git a/test/starlark_tests/rules/order_files_tests_setup.bzl b/test/starlark_tests/rules/order_files_tests_setup.bzl
new file mode 100644
index 00000000..6268fb87
--- /dev/null
+++ b/test/starlark_tests/rules/order_files_tests_setup.bzl
@@ -0,0 +1,95 @@
+# Copyright 2023 The Bazel Authors. All rights reserved.
